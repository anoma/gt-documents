					"uidString" : "4MyAWU3MQLCJJIiY8mUNYQ=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "These are the guys that build blocks"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [ ]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:00:07.067185+08:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:01:25.51812+08:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "rqxR2t6gTJGkEqjNu5ofng=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "Are you always wanting inclusion often? One trick you can pull is by making deal with block builders."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [ ]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:01:26.445982+08:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:02:41.016162+08:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "MqAkywx7QhKSeGxZuF5QKw=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "A good way to look for this is to look at the landscape of who actually builds blocks and send order flow to them. For example like [[Titan]]. They are incentivized to accept this as they can use this information to front run your transactions or have a more complete order set they can utilize for whatever purposes they might use it for."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [ ]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:02:41.690292+08:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:03:04.946768+08:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "Yo7wHp7HS3KwuHVIYD1YtQ=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "This is also beneficial to you, as you can force inclusion likely for a cheaper price at the cost of exclusive orderflow."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [ ]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:03:06.372402+08:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:06:33.509409+08:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "WNfHQ2VFTTaG3UOo2E2Yuw=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "One benefit of this is that your transactions stay out of the general mempool meaning you won't be frontrun by all entities, only those who collaborate with the block builder."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [
									{
										"__type" : "textSnippet",
										"children" : {
											"__type" : "snippets",
											"items" : [ ]
										},
										"createEmail" : {
											"__type" : "email",
											"emailString" : "<unknown>"
										},
										"createTime" : {
											"__type" : "time",
											"time" : {
												"__type" : "dateAndTime",
												"dateAndTimeString" : "2026-05-12T21:10:00.20885+08:00"
											}
										},
										"editEmail" : {
											"__type" : "email",
											"emailString" : "<unknown>"
										},
										"editTime" : {
											"__type" : "time",
											"time" : {
												"__type" : "dateAndTime",
												"dateAndTimeString" : "2026-05-12T21:10:11.560891+08:00"
											}
										},
										"uid" : {
											"__type" : "uid",
											"uidString" : "RyR39Gf6SyG7zwZquGlhYw=="
										},
										"paragraphStyle" : {
											"__type" : "textStyle"
										},
										"string" : "If there is call data that is variable to chain state this can of course fail"
									}
								]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:08:24.487485+08:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:09:58.731825+08:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "3eYVfOUwRI+jRKIoyldCaQ=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "This means we **know** what blocks are included. Meaning we can give [[preconfirmations]] to users and update our plan with the idea that a transaction can always be included. This has some interesting implications though"
						}
					]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
