								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:13:28.600699+08:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:15:11.490589+08:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "DE5px9JrRM6vEniNrYg0mQ=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "If we know the makeup of the market then we can collaborate with multiple block builders. Getting a 95-99% inclusion rate."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [ ]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:15:59.586924+08:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-12T21:16:38.69732+08:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "I3yhDVZORrSR0+/ENh7PrQ=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "The benefit to us is that we do not post on the public mempool and get frontrun by everyone. Instead our front and backrun exposure is only by the entities these parties collaborate with."
						},
						{
							"__type" : "textSnippet",
							"children" : {
